{
  "name": "streamerhub",
  "version": "1.0.1",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "start": "node app.js",
    "desktop": "electron .",
    "dist:win": "electron-builder --win nsis",
    "audit:fix": "npm audit fix",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "prune:prod": "npm prune --omit=dev",
    "verify:js": "node --check app.js && node --check electron-main.js && node --check preload.js && node --check assets/js/core/app-bootstrap.js && node --check assets/js/modules/market/market-overlay.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^1.25.0",
    "body-parser": "^1.20.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "firebase-admin": "^13.4.0",
    "helmet": "^8.1.0",
    "memorystore": "^1.6.7",
    "node-fetch": "^2.7.0",
    "socket.io": "^4.8.1",
    "stripe": "^18.4.0",
    "openid": "^2.0.14"
  },
  "devDependencies": {
    "electron": "^37.3.1",
    "electron-builder": "^26.1.0"
  },
  "overrides": {
    "semver": "^7.7.3",
    "ws": "^8.18.3",
    "tar": "^7.4.3",
    "brace-expansion": "^4.0.1",
    "form-data": "^4.0.4",
    "elliptic": "^6.6.1",
    "tmp": "^0.2.4",
    "lodash": "^4.17.21",
    "cross-spawn": "^7.0.6",
    "ansi-regex": "^6.2.2",
    "serialize-javascript": "^6.0.2",
    "nanoid": "^3.3.11"
  }
}
