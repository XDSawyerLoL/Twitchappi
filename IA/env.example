# ORYON / IA — exemple de variables d'environnement
PORT=8787
NODE_ENV=development

# CORS
# Exemple: http://localhost:8787,http://localhost:10000,https://mon-domaine.fr
CORS_ORIGINS=http://localhost:8787,http://localhost:10000

# Fournisseurs IA
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
OPERATOR_PROVIDERS=gemini

# GitHub
GITHUB_TOKEN=
DEFAULT_REPO_OWNER=
DEFAULT_REPO_NAME=

# Build / logs
BUILD_ID=local
